{
  "name": "skill-steward",
  "version": "0.5.0-alpha.2",
  "description": "Local-first discovery, preflight, and reversible Skill operations across AI harnesses",
  "license": "MIT",
  "keywords": [
    "agent-skills",
    "codex",
    "claude-code",
    "github-copilot",
    "developer-tools"
  ],
  "private": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "skill-steward": "./dist/main.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --filter @skill-steward/dashboard build && node build.mjs",
    "pretest": "pnpm build",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm --filter \"skill-steward^...\" build && pnpm build"
  },
  "devDependencies": {
    "@skill-steward/catalog": "workspace:*",
    "@skill-steward/dashboard": "workspace:*",
    "@skill-steward/dashboard-server": "workspace:*",
    "@skill-steward/engine": "workspace:*",
    "@skill-steward/evidence": "workspace:*",
    "@skill-steward/governance": "workspace:*",
    "@skill-steward/insights": "workspace:*",
    "@skill-steward/integrations": "workspace:*",
    "@skill-steward/installer": "workspace:*",
    "@skill-steward/preflight": "workspace:*",
    "@skill-steward/report": "workspace:*",
    "@skill-steward/store": "workspace:*",
    "commander": "^14.0.0"
  }
}
